{
  "name": "@tonycletus/wails-release-kit",
  "version": "0.1.0",
  "description": "CLI scaffolding for Wails desktop GitHub Releases with Windows, macOS, Linux, icons, and stable asset URLs.",
  "type": "module",
  "license": "MIT",
  "author": "Tony Cletus",
  "homepage": "https://github.com/tonycletus/wails-release-kit#readme",
  "bugs": {
    "url": "https://github.com/tonycletus/wails-release-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tonycletus/wails-release-kit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "wails",
    "go",
    "github-actions",
    "desktop",
    "release",
    "dmg",
    "deb",
    "inno-setup"
  ],
  "bin": {
    "wails-release-kit": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsup": "^8.3.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
